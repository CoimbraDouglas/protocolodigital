DATABASE_URL="postgresql://usuario:senha@localhost:5432/protocolodigital"
JWT_SECRET="sua_chave_secreta_aqui"
PORT=3001

# --- E-mail (notificações) ---
# Deixe estas variáveis em branco para DESABILITAR o envio de e-mails.
# O sistema funciona normalmente sem elas (apenas não envia notificação).
#
# Gmail / Google Workspace (ex.: @csa.g12.br):
#   - Ative a verificação em duas etapas na conta Google
#   - Gere uma "Senha de app" e use-a em SMTP_PASS (NÃO a senha normal)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="seu_email@csa.g12.br"
SMTP_PASS="senha_de_app_16_digitos"
EMAIL_FROM="Protocolo Digital <seu_email@csa.g12.br>"

# URL pública do sistema (usada no link dos e-mails). Ex.: em produção:
APP_URL="https://protocolodigital.onrender.com"
